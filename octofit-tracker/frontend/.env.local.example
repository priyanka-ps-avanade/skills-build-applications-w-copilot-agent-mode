# GitHub Codespaces Environment Configuration
# Copy this file to .env.local and update with your actual Codespace name

# Your GitHub Codespaces name (e.g., priyanka-ps-avanade-9xj45x)
# Find this in your Codespace URL: https://{CODESPACE_NAME}-8000.app.github.dev
VITE_CODESPACE_NAME=your-codespace-name
