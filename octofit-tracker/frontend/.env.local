# GitHub Codespaces environment configuration for Octofit Tracker Frontend
# 
# Required: Set this to your GitHub Codespaces name
# Example: VITE_CODESPACE_NAME=priyanka-ps-avanade-9xj45x
#
# The API endpoints will be constructed as:
# https://${VITE_CODESPACE_NAME}-8000.app.github.dev/api/[component]/
#
VITE_CODESPACE_NAME=your-codespace-name
